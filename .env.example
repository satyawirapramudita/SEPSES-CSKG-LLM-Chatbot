# ============================================================
# SEPSES CSKG LLM Chatbot - Environment Variables Template
# SALIN file ini menjadi .env dan ISI nilainya.
# JANGAN pernah commit file .env ke repository!
# ============================================================

# ---- OpenAI Configuration (LLM 1: GPT-4o-mini) ----
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ---- Ollama Configuration (LLM 2: Mistral-7B) ----
# Jalankan: ollama pull mistral
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ---- SEPSES SPARQL Endpoint ----
# Endpoint publik (default). Jika tidak tersedia, gunakan Fuseki lokal.
SPARQL_ENDPOINT=https://w3id.org/sepses/sparql
SPARQL_TIMEOUT_SECONDS=30

# ---- Apache Jena Fuseki (Local Fallback) ----
FUSEKI_ENDPOINT=http://localhost:3030/sepses/sparql
FUSEKI_UPDATE_ENDPOINT=http://localhost:3030/sepses/update

# ---- ChromaDB Vector Store ----
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION_LOGS=security_logs
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- Evaluation Settings ----
# Model yang digunakan sebagai judge untuk LLM-as-a-Judge
JUDGE_MODEL=gpt-4o-mini
EVAL_RESULTS_DIR=./evaluation/results

# ---- Application Settings ----
LOG_LEVEL=INFO
MAX_CONTEXT_TOKENS=4000
TOP_K_RETRIEVAL=5
